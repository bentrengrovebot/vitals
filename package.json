{
  "name": "vitals",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "prisma generate && cd client && npm install && npm run build",
    "start": "node server/start.js",
    "postinstall": "prisma generate && cd client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.5.0",
    "resend": "^4.1.2"
  }
}
