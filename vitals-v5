                      <span style={{fontSize:12,fontWeight:700,color:isLight?rd:isHeavy?or:t1}}>Target</span>
                    </div>
                    <span style={{fontSize:15,fontWeight:800,color:isLight?rd:isHeavy?or:t1}}>{pmt.cal} cal</span>
                  </div>
                  <div style={{display:"flex",gap:10,marginTop:6}}>
                    <span style={{fontSize:11,fontWeight:600,color:ac}}>{pmt.protein}g P</span>
                    <span style={{fontSize:11,fontWeight:600,color:or}}>{pmt.fat}g F</span>
                    <span style={{fontSize:11,fontWeight:600,color:gn}}>{pmt.carbs}g C</span>
                  </div>
                  {isLight&&<div style={{fontSize:10,color:rd,marginTop:4,fontWeight:500}}>Light meal needed — you've used {pctUsed}% of your daily budget</div>}
                </div>
