        </div>

        {/* Weekly calendar row */}
        {(()=>{const w=getWeekData();if(w.logged<1)return null;return(
          <div style={{padding:"8px 20px 4px"}}>
            <div style={{...card,padding:"14px 16px"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
