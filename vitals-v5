                <div><div style={{fontSize:10,opacity:0.5,fontWeight:600}}>Per meal</div><div style={{fontSize:22,fontWeight:800}}>{pmt.cal} <span style={{fontSize:11,opacity:0.5}}>cal</span></div><div style={{fontSize:11,opacity:0.6,marginTop:2}}>{pmt.protein}g P · {pmt.fat}g F · {pmt.carbs}g C</div></div>
