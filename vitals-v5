          {eRec.ingredients.length>0&&(()=>{const ps=recN(eRec);return(<div style={{...card,padding:"16px 18px",marginBottom:16,background:"linear-gradient(135deg,#3b82f6,#8b5cf6)",color:"#fff"}}><div style={{fontSize:10,fontWeight:700,opacity:0.6,textTransform:"uppercase",marginBottom:8,letterSpacing:"0.5px"}}>Per Serve</div><div style={{display:"flex",gap:14}}><div><span style={{fontSize:24,fontWeight:800}}>{ps.cal}</span> <span style={{fontSize:12,opacity:0.6}}>Cal</span></div><div><span style={{fontSize:18,fontWeight:700}}>{ps.protein}g</span> <span style={{fontSize:11,opacity:0.6}}>P</span></div><div><span style={{fontSize:18,fontWeight:700}}>{ps.fat}g</span> <span style={{fontSize:11,opacity:0.6}}>F</span></div><div><span style={{fontSize:18,fontWeight:700}}>{ps.carbs}g</span> <span style={{fontSize:11,opacity:0.6}}>C</span></div></div></div>);})()}
