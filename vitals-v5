              </div>
            </div>
          </div>
        );})()}

        {/* Meal slots */}
        <div style={{padding:"6px 20px 0"}}>
          {SLOTS.map(slot=>{
            const items=day[slot]||[];const st=slTot(slot);const col=SLOT_COL[slot];const empty=items.length===0;
            const pmt=perMealTarget();const rem=getRemaining();const ml=mealsLeft();
            const showTarget=empty&&curDate===dk()&&ml>0&&tot.cal>0;
            // Check if rebalance is significant (eaten >30% of remaining in fewer meals)
            const pctUsed=goals.calories>0?Math.round((tot.cal/goals.calories)*100):0;
            const isLight=pmt.cal<(goals.calories/4)*0.5&&ml<=2&&pctUsed>60;
            const isHeavy=pmt.cal>(goals.calories/4)*1.5&&ml>=2;
            return(<div key={slot} style={{...card,marginBottom:8,padding:0}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"12px 16px 6px"}}>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
