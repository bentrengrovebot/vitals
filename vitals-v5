        </div>

        {/* Symptoms */}
        {(()=>{const ds=symptoms.filter(s=>dk(new Date(s.timestamp))===curDate);if(!ds.length)return null;return(<div style={{padding:"4px 20px 0"}}><div style={{fontSize:11,fontWeight:700,color:t3,textTransform:"uppercase",marginBottom:6,letterSpacing:"0.5px"}}>Symptoms</div><div style={{display:"flex",flexWrap:"wrap",gap:6}}>{ds.map(s=>{const st=SYMPTOMS.find(t=>t.id===s.type);return(<div key={s.id} style={{fontSize:12,padding:"5px 11px",borderRadius:10,background:st?.color+"12",border:`1px solid ${st?.color}25`,color:st?.color,fontWeight:600}}>{st?.icon} {st?.label} {s.severity}/5</div>);})}</div></div>);})()}

        {/* Water tracking */}
        {curDate===dk()&&(()=>{
          const todayWater=waterLogs.filter(w=>dk(new Date(w.timestamp))===dk());
          const totalMl=todayWater.reduce((s,w)=>s+w.amountMl,0);
          const pctW=waterGoal>0?Math.min(100,Math.round((totalMl/waterGoal)*100)):0;
          const lastEntry=todayWater.length>0?todayWater.sort((a,b)=>b.timestamp-a.timestamp)[0]:null;
          const timeSinceLast=lastEntry?Math.round((Date.now()-lastEntry.timestamp)/60000):null;
          const addWater=async(ml)=>{await _wl([{id:uid(),timestamp:Date.now(),amountMl:ml},...waterLogs]);};
          return(
            <div style={{padding:"8px 20px 0"}}>
              <div style={{...card,padding:"14px 16px"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                  <div style={{display:"flex",alignItems:"center",gap:8}}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" strokeWidth="2" strokeLinecap="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                    <span style={{fontSize:14,fontWeight:700}}>Water</span>
                    {timeSinceLast!==null&&timeSinceLast>120&&<span style={{fontSize:10,color:or,fontWeight:600,background:or+"12",padding:"2px 8px",borderRadius:6}}>Last: {timeSinceLast>60?`${Math.floor(timeSinceLast/60)}h ago`:`${timeSinceLast}m ago`}</span>}
                  </div>
                  <span style={{fontSize:15,fontWeight:800,color:pctW>=100?gn:t1}}>{r1(totalMl/1000)}L <span style={{fontSize:11,fontWeight:500,color:t3}}>/ {r1(waterGoal/1000)}L</span></span>
                </div>
                <div style={{height:6,borderRadius:3,background:brd,marginBottom:10}}>
                  <div style={{height:6,borderRadius:3,background:pctW>=100?gn:ac,width:`${pctW}%`,transition:"width 0.3s"}}/>
                </div>
                <div style={{display:"flex",gap:6}}>
                  {[250,500,750].map(ml=>(
                    <button key={ml} onClick={()=>addWater(ml)} style={{flex:1,padding:"10px 0",borderRadius:10,border:`1.5px solid ${ac}20`,background:ac+"08",color:ac,fontSize:13,fontWeight:700,cursor:"pointer"}}>+ {ml>=1000?`${ml/1000}L`:`${ml}ml`}</button>
                  ))}
                </div>
                {/* Expandable timeline */}
                {todayWater.length>0&&(
                  <div>
                    <button onClick={()=>setWaterExpanded(!waterExpanded)} style={{background:"none",border:"none",color:t3,fontSize:11,fontWeight:600,cursor:"pointer",padding:"8px 0 0",width:"100%",textAlign:"left"}}>{waterExpanded?"Hide entries ▲":`${todayWater.length} entries today ▼`}</button>
