import { useState, useEffect, useRef } from "react";

const SLOTS = ["Breakfast", "Lunch", "Dinner", "Snacks"];
const SYMPTOMS = [
  { id: "reflux", label: "Reflux", icon: "🔥", color: "#ef4444" },
  { id: "bloating", label: "Bloating", icon: "🫧", color: "#8b5cf6" },
  { id: "energy_high", label: "Energy ↑", icon: "⚡", color: "#f59e0b" },
  { id: "energy_low", label: "Energy ↓", icon: "😴", color: "#6b7280" },
  { id: "mood_good", label: "Mood ↑", icon: "😊", color: "#22c55e" },
  { id: "mood_bad", label: "Mood ↓", icon: "😤", color: "#ef4444" },
  { id: "headache", label: "Headache", icon: "🤕", color: "#ec4899" },
  { id: "gut_good", label: "Gut Good", icon: "✅", color: "#10b981" },
];
const SLOT_COL = { Breakfast: "#f59e0b", Lunch: "#3b82f6", Dinner: "#8b5cf6", Snacks: "#10b981" };
const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
const r1 = (n) => Math.round(n * 10) / 10;
async function ld(k, fb) { try { const r = await window.storage.get(k); return r ? JSON.parse(r.value) : fb; } catch { return fb; } }
async function sv(k, v) { try { await window.storage.set(k, JSON.stringify(v)); } catch (e) { console.error(e); } }
const dk = (d = new Date()) => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
const fmtD = (k) => { const d=new Date(k+"T00:00:00"),t=new Date(),y=new Date();y.setDate(y.getDate()-1); if(d.toDateString()===t.toDateString())return"Today";if(d.toDateString()===y.toDateString())return"Yesterday";return d.toLocaleDateString("en-NZ",{weekday:"short",day:"numeric",month:"short"});};
const shift = (k, n) => { const d=new Date(k+"T00:00:00");d.setDate(d.getDate()+n);return dk(d);};
const greet = () => { const h=new Date().getHours(); return h<12?"Good morning":h<17?"Good afternoon":"Good evening";};
const DPRO = { name:"",dob:"",sex:"Male",height:"",weight:"",weightGoal:"" };
const DGOALS = { calories:2300,protein:150,fat:80,carbs:250 };

export default function Vitals() {
  const [sc, setSc] = useState("diary");
  const [rdy, setRdy] = useState(false);
  const [diary, setDiary] = useState({});
  const [recipes, setRecipes] = useState([]);
  const [foods, setFoods] = useState([]);
  const [symptoms, setSymptoms] = useState([]);
  const [insights, setInsights] = useState([]);
  const [goals, setGoals] = useState(DGOALS);
  const [profile, setProfile] = useState(DPRO);
  const [weighIns, setWeighIns] = useState([]);
  const [waterLogs, setWaterLogs] = useState([]); // [{id, timestamp, amountMl}]
  const [waterGoal, setWaterGoal] = useState(2500); // ml
  const [supps, setSupps] = useState([]); // [{id, name, activeIngredient, activeDose, isActive}]
  const [suppLogs, setSuppLogs] = useState([]); // [{id, supplementId, date, takenAt}]
  const [suppForm, setSuppForm] = useState({name:"",ingredient:"",dose:""});
  const [addingSupp, setAddingSupp] = useState(false);
  const [waterExpanded, setWaterExpanded] = useState(false);
  const [curDate, setCurDate] = useState(dk());
  const [pSlot, setPSlot] = useState("Lunch");
  const [pTab, setPTab] = useState("recipes");
  const [search, setSearch] = useState("");
  const [eRec, setERec] = useState(null);
  const [addIng, setAddIng] = useState(false);
  const [ingF, setIngF] = useState({name:"",grams:"",cal:"",protein:"",fat:"",carbs:""});
  const [est, setEst] = useState(false);
  const [symF, setSymF] = useState({type:null,severity:3,notes:""});
  const [insLoad, setInsLoad] = useState(false);
  const [insDays, setInsDays] = useState(7);
  const [del, setDel] = useState(null);
  const [mp, setMp] = useState(0);
  const [aiM, setAiM] = useState([]);
  const [aiI, setAiI] = useState("");
  const [aiL, setAiL] = useState(false);
  const [sTab, setSTab] = useState("profile");
  const [wiVal, setWiVal] = useState("");
  const [confirmClear, setConfirmClear] = useState(false);
  const chatEnd = useRef(null);

  useEffect(()=>{(async()=>{
    const [d,r,f,s,i,g,p,w,wl,wg,sp,sl]=await Promise.all([ld("v:diary",{}),ld("v:recipes",[]),ld("v:foods",[]),ld("v:symptoms",[]),ld("v:insights",[]),ld("v:goals",null),ld("v:profile",null),ld("v:weighins",[]),ld("v:water",[]),ld("v:watergoal",2500),ld("v:supps",[]),ld("v:supplogs",[])]);
    setDiary(d);setRecipes(r);setFoods(f);setSymptoms(s);setInsights(i);if(g)setGoals(g);if(p)setProfile(p);setWeighIns(w);setWaterLogs(wl);setWaterGoal(wg);setSupps(sp);setSuppLogs(sl);setRdy(true);
  })();},[]);

  const _d=async(d)=>{setDiary(d);await sv("v:diary",d);};
  const _r=async(r)=>{setRecipes(r);await sv("v:recipes",r);};
  const _f=async(f)=>{setFoods(f);await sv("v:foods",f);};
  const _s=async(s)=>{setSymptoms(s);await sv("v:symptoms",s);};
  const _i=async(i)=>{setInsights(i);await sv("v:insights",i);};
  const _g=async(g)=>{setGoals(g);await sv("v:goals",g);};
  const _p=async(p)=>{setProfile(p);await sv("v:profile",p);};
  const _w=async(w)=>{setWeighIns(w);await sv("v:weighins",w);};
  const _wl=async(w)=>{setWaterLogs(w);await sv("v:water",w);};
  const _wg=async(g)=>{setWaterGoal(g);await sv("v:watergoal",g);};
  const _sp=async(s)=>{setSupps(s);await sv("v:supps",s);};
  const _sl=async(s)=>{setSuppLogs(s);await sv("v:supplogs",s);};

  const dayE=(k)=>diary[k]||{Breakfast:[],Lunch:[],Dinner:[],Snacks:[]};
  const day=dayE(curDate);
  const addE=async(slot,item)=>{const d={...diary};if(!d[curDate])d[curDate]={Breakfast:[],Lunch:[],Dinner:[],Snacks:[]};d[curDate][slot]=[...(d[curDate][slot]||[]),{...item,id:uid(),timestamp:Date.now()}];await _d(d);};
  const remE=async(slot,id)=>{const d={...diary};if(d[curDate]?.[slot]){d[curDate][slot]=d[curDate][slot].filter(e=>e.id!==id);await _d(d);}setDel(null);};

  const recN=(rec)=>{if(!rec?.ingredients?.length)return{cal:0,protein:0,fat:0,carbs:0};const t=rec.ingredients.reduce((a,i)=>({cal:a.cal+(i.cal||0),protein:a.protein+(i.protein||0),fat:a.fat+(i.fat||0),carbs:a.carbs+(i.carbs||0)}),{cal:0,protein:0,fat:0,carbs:0});const s=rec.servings||1;return{cal:r1(t.cal/s),protein:r1(t.protein/s),fat:r1(t.fat/s),carbs:r1(t.carbs/s)};};

  const dayTot=()=>{let c=0,p=0,f=0,cb=0;SLOTS.forEach(sl=>(day[sl]||[]).forEach(i=>{c+=i.cal||0;p+=i.protein||0;f+=i.fat||0;cb+=i.carbs||0;}));return{cal:r1(c),protein:r1(p),fat:r1(f),carbs:r1(cb)};};
  const slTot=(sl)=>{let c=0,p=0,f=0,cb=0;(day[sl]||[]).forEach(i=>{c+=i.cal||0;p+=i.protein||0;f+=i.fat||0;cb+=i.carbs||0;});return{cal:r1(c),protein:r1(p),fat:r1(f),carbs:r1(cb)};};
  const tot=dayTot();
  const pct=goals.calories>0?Math.min(100,Math.round((tot.cal/goals.calories)*100)):0;

  // Streak
  const getStreak=()=>{let s=0,d=dk();while(true){const de=diary[d];if(de&&SLOTS.some(sl=>de[sl]?.length>0)){s++;d=shift(d,-1);}else break;}return s;};
  const streak=getStreak();

  // Weekly data
  const getWeekData=()=>{
    const today=dk();const dow=new Date().getDay();const mo=dow===0?-6:1-dow;
    const ws=shift(today,mo);const days=[];
    for(let i=0;i<7;i++){const d=shift(ws,i);const de=dayE(d);let c=0,p=0;SLOTS.forEach(sl=>(de[sl]||[]).forEach(it=>{c+=it.cal||0;p+=it.protein||0;}));const hasData=SLOTS.some(sl=>de[sl]?.length>0);days.push({dk:d,cal:r1(c),protein:r1(p),hasData,dayName:new Date(d+"T00:00:00").toLocaleDateString("en-NZ",{weekday:"short"}).charAt(0)});}
    const totalCal=days.reduce((s,d)=>s+d.cal,0);const logged=days.filter(d=>d.hasData).length;
    return{days,totalCal:r1(totalCal),logged,weekGoal:goals.calories*7,ws};
  };

  // Remaining targets for next meal
  const getRemaining=()=>{
    const eaten={cal:tot.cal,protein:tot.protein,fat:tot.fat,carbs:tot.carbs};
    return{cal:r1(Math.max(0,goals.calories-eaten.cal)),protein:r1(Math.max(0,goals.protein-eaten.protein)),fat:r1(Math.max(0,goals.fat-eaten.fat)),carbs:r1(Math.max(0,goals.carbs-eaten.carbs))};
  };
  // How many meals left today
  const mealsLeft=()=>{let count=0;SLOTS.forEach(sl=>{if(!(day[sl]?.length>0))count++;});return count;};
  const perMealTarget=()=>{const rem=getRemaining();const ml=Math.max(1,mealsLeft());return{cal:r1(rem.cal/ml),protein:r1(rem.protein/ml),fat:r1(rem.fat/ml),carbs:r1(rem.carbs/ml)};};

  // Profile context
  const profCtx=()=>{let c="";if(profile.name)c+=`Name: ${profile.name}\n`;if(profile.sex)c+=`Sex: ${profile.sex}\n`;if(profile.dob){const age=Math.floor((Date.now()-new Date(profile.dob).getTime())/(365.25*86400000));c+=`Age: ${age}\n`;}if(profile.height)c+=`Height: ${profile.height}cm\n`;if(profile.weight)c+=`Weight: ${profile.weight}kg\n`;if(profile.weightGoal)c+=`Goal weight: ${profile.weightGoal}kg\n`;if(weighIns.length)c+=`Recent weigh-ins: ${weighIns.slice(0,10).map(w=>`${w.date}: ${w.weight}kg`).join(", ")}\n`;c+=`Goals: ${goals.calories}cal, ${goals.protein}g P, ${goals.fat}g F, ${goals.carbs}g C\n`;return c;};

  // AI estimation
  const estN=async(name,grams)=>{setEst(true);try{const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:200,system:"Nutrition database. Given food+grams, respond ONLY JSON: {\"cal\":number,\"protein\":number,\"fat\":number,\"carbs\":number}. NZ brands. 1dp.",messages:[{role:"user",content:`"${name}", ${grams}g`}]})});const data=await res.json();const txt=(data.content?.[0]?.text||"").replace(/```json|```/g,"").trim();const p=JSON.parse(txt);setIngF(f=>({...f,cal:String(p.cal||0),protein:String(p.protein||0),fat:String(p.fat||0),carbs:String(p.carbs||0)}));}catch(e){console.error(e);}setEst(false);};

  // AI Insight
  const runIns=async()=>{setInsLoad(true);const ds=[];for(let i=0;i<insDays;i++)ds.push(shift(dk(),-i));let ft="";ds.forEach(d=>{const de=dayE(d);const has=SLOTS.some(s=>de[s]?.length>0);if(has){ft+=`\n${fmtD(d)}:\n`;SLOTS.forEach(s=>{if(de[s]?.length)de[s].forEach(it=>{ft+=`  ${s}: ${it.name} (${it.cal}cal P:${it.protein}g F:${it.fat}g C:${it.carbs}g)\n`;});});}});const syR=symptoms.filter(s=>{const sd=dk(new Date(s.timestamp));return ds.includes(sd);});const st=syR.map(s=>{const t=SYMPTOMS.find(x=>x.id===s.type);return`  ${new Date(s.timestamp).toLocaleDateString("en-NZ")}: ${t?.label} (${s.severity}/5)${s.notes?" — "+s.notes:""}`;}).join("\n");if(!ft&&!st){setInsLoad(false);alert("No data.");return;}try{const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,system:`Personal health analyst & nutrition coach. Direct, specific, NZ English. Adherence-neutral.\n\nAnalyse: 1) Cal/macro adherence 2) Estimated TDEE from weight trend 3) Food→symptom correlations 4) Meal timing 5) Weight trajectory 6) One actionable recommendation 7) Target adjustment suggestion\n\nPROFILE:\n${profCtx()}`,messages:[{role:"user",content:`FOOD:${ft||"\n(none)"}\n\nSYMPTOMS:\n${st||"(none)"}`}]})});const data=await res.json();const txt=data.content?.map(c=>c.text||"").join("\n")||"No response.";await _i([{id:uid(),timestamp:Date.now(),days:insDays,response:txt},...insights]);}catch(e){alert("Failed.");}setInsLoad(false);};

  // AI Chat
  const sendChat=async()=>{if(!aiI.trim()||aiL)return;const msg=aiI.trim();setAiI("");const msgs=[...aiM,{role:"user",content:msg}];setAiM(msgs);setAiL(true);let ctx=`PROFILE:\n${profCtx()}\n\nFOOD (7d):\n`;for(let i=0;i<7;i++){const d=shift(dk(),-i);const de=dayE(d);const has=SLOTS.some(s=>de[s]?.length>0);if(has){ctx+=`${fmtD(d)}:\n`;SLOTS.forEach(s=>{if(de[s]?.length)de[s].forEach(it=>{ctx+=`  ${s}: ${it.name} (${it.cal}cal P:${it.protein}g)\n`;});});}}const rS=symptoms.slice(0,20);if(rS.length){ctx+="\nSYMPTOMS:\n";rS.forEach(s=>{const t=SYMPTOMS.find(x=>x.id===s.type);ctx+=`  ${new Date(s.timestamp).toLocaleDateString("en-NZ")}: ${t?.label} (${s.severity}/5)\n`;});}try{const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,system:`You are Vitals — a personal health coach. Concise, direct, specific. NZ English. Adherence-neutral.\n\nIMPORTANT: Users will report symptoms conversationally (e.g. "getting reflux", "feeling tired", "bloated after lunch"). When they do, acknowledge it and immediately correlate with their recent food, water, supplement, and sleep data. Reference specific meals, timing, and patterns. Tell them WHY it might be happening.\n\nCan estimate TDEE, do weekly check-ins, suggest day rebalancing, recommend target adjustments.\n\n${ctx}`,messages:msgs.map(m=>({role:m.role,content:m.content}))})});const data=await res.json();const txt=data.content?.map(c=>c.text||"").join("\n")||"Error.";setAiM([...msgs,{role:"assistant",content:txt}]);}catch(e){setAiM([...msgs,{role:"assistant",content:"Connection error."}]);}setAiL(false);};
  useEffect(()=>{chatEnd.current?.scrollIntoView({behavior:"smooth"});},[aiM]);

  const saveRec=async(rec)=>{const idx=recipes.findIndex(r=>r.id===rec.id);const upd=idx>=0?recipes.map(r=>r.id===rec.id?rec:r):[...recipes,rec];await _r(upd);setERec(rec);};
  const clearAll=async()=>{await _d({});await _r([]);await _f([]);await _s([]);await _i([]);await _w([]);await _wl([]);await _sl([]);setAiM([]);setConfirmClear(false);};

  // ─── STYLES ───
  const bg="#f8f8fa",wh="#ffffff",brd="#eaeaef",t1="#111827",t2="#6b7280",t3="#9ca3af",ac="#3b82f6",gn="#22c55e",or="#f59e0b",pu="#8b5cf6",rd="#ef4444";
  const card={background:wh,borderRadius:16,boxShadow:"0 1px 4px rgba(0,0,0,0.05)",overflow:"hidden"};
  const inp={width:"100%",padding:"14px 16px",borderRadius:12,border:`1.5px solid ${brd}`,background:wh,color:t1,fontSize:15,fontFamily:"inherit",boxSizing:"border-box",outline:"none"};
  const btnA={width:"100%",padding:"16px",borderRadius:14,border:"none",background:ac,color:"#fff",fontSize:15,fontWeight:700,cursor:"pointer"};
  const pill=(a,c=ac)=>({padding:"7px 16px",borderRadius:20,fontSize:13,fontWeight:600,cursor:"pointer",border:a?"none":`1.5px solid ${brd}`,background:a?c:wh,color:a?"#fff":t2});

  if(!rdy)return(<div style={{height:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:bg,fontFamily:"-apple-system,system-ui,sans-serif"}}><div style={{fontSize:28,fontWeight:800,color:t1}}>Vitals</div></div>);

  return(
    <div style={{minHeight:"100vh",background:bg,color:t1,fontFamily:"-apple-system,system-ui,sans-serif",maxWidth:480,margin:"0 auto",position:"relative"}}>

      {/* DELETE */}
      {del&&(<div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.3)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:20}} onClick={()=>setDel(null)}><div onClick={e=>e.stopPropagation()} style={{...card,padding:24,width:"100%",maxWidth:300}}><div style={{fontSize:17,fontWeight:700,marginBottom:6}}>Delete?</div><div style={{fontSize:14,color:t2,marginBottom:20}}>{del.label}</div><div style={{display:"flex",gap:10}}><button onClick={()=>setDel(null)} style={{flex:1,padding:12,borderRadius:12,border:`1px solid ${brd}`,background:wh,color:t1,fontSize:14,fontWeight:600,cursor:"pointer"}}>Cancel</button><button onClick={del.action} style={{flex:1,padding:12,borderRadius:12,border:"none",background:rd,color:"#fff",fontSize:14,fontWeight:600,cursor:"pointer"}}>Delete</button></div></div></div>)}

      {/* ═══ DIARY ═══ */}
      {sc==="diary"&&(<div style={{paddingBottom:100}}>
        {/* Header */}
        <div style={{padding:"20px 20px 0",display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
          <div>
            <div style={{fontSize:13,color:t3,fontWeight:500,letterSpacing:"0.2px"}}>{new Date().toLocaleDateString("en-NZ",{weekday:"long",day:"numeric",month:"long"})}</div>
            <div style={{fontSize:26,fontWeight:800,letterSpacing:"-0.5px",marginTop:2}}>{greet()}{profile.name?`, ${profile.name}`:""} 👋</div>
          </div>
          {streak>0&&(<div style={{background:"linear-gradient(135deg,#f59e0b,#ef4444)",borderRadius:14,padding:"8px 14px",display:"flex",alignItems:"center",gap:6}}><span style={{fontSize:18}}>🔥</span><div><div style={{fontSize:18,fontWeight:800,color:"#fff",lineHeight:1}}>{streak}</div><div style={{fontSize:8,fontWeight:700,color:"rgba(255,255,255,0.8)",textTransform:"uppercase",letterSpacing:"0.5px"}}>streak</div></div></div>)}
        </div>

        {/* Date nav */}
        <div style={{display:"flex",alignItems:"center",justifyContent:"center",padding:"14px 20px 6px",gap:20}}>
          <button onClick={()=>setCurDate(d=>shift(d,-1))} style={{width:36,height:36,borderRadius:12,background:wh,border:`1px solid ${brd}`,color:t2,fontSize:18,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>‹</button>
          <div style={{fontSize:16,fontWeight:700,minWidth:120,textAlign:"center"}}>{fmtD(curDate)}</div>
          <button onClick={()=>setCurDate(d=>shift(d,1))} style={{width:36,height:36,borderRadius:12,background:wh,border:`1px solid ${brd}`,color:t2,fontSize:18,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>›</button>
        </div>

        {/* Calorie hero card */}
        <div style={{padding:"8px 20px 4px"}} onClick={()=>setMp(p=>(p+1)%3)}>
          <div style={{...card,padding:"22px 20px",background:"linear-gradient(135deg,#3b82f6 0%,#8b5cf6 100%)",color:"#fff",cursor:"pointer"}}>
            {mp===0&&(<div style={{display:"flex",alignItems:"center",gap:20}}>
              <div style={{position:"relative",width:76,height:76,flexShrink:0}}>
                <svg width="76" height="76" viewBox="0 0 76 76"><circle cx="38" cy="38" r="33" fill="none" stroke="rgba(255,255,255,0.15)" strokeWidth="7"/><circle cx="38" cy="38" r="33" fill="none" stroke="#fff" strokeWidth="7" strokeDasharray={`${(pct/100)*207.3} 207.3`} strokeLinecap="round" transform="rotate(-90 38 38)" style={{transition:"all 0.4s"}}/></svg>
                <div style={{position:"absolute",inset:0,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center"}}><div style={{fontSize:22,fontWeight:800,lineHeight:1}}>{pct}%</div></div>
              </div>
              <div style={{flex:1}}>
                <div style={{display:"flex",justifyContent:"space-between"}}>
                  <div><div style={{fontSize:10,opacity:0.6,fontWeight:700,letterSpacing:"0.5px"}}>GOAL</div><div style={{fontSize:22,fontWeight:800,lineHeight:1.2}}>{goals.calories}</div></div>
                  <div><div style={{fontSize:10,opacity:0.6,fontWeight:700,letterSpacing:"0.5px"}}>EATEN</div><div style={{fontSize:22,fontWeight:800,lineHeight:1.2}}>{tot.cal}</div></div>
                  <div><div style={{fontSize:10,opacity:0.6,fontWeight:700,letterSpacing:"0.5px"}}>LEFT</div><div style={{fontSize:22,fontWeight:800,lineHeight:1.2,color:goals.calories-tot.cal<0?"#fca5a5":"#fff"}}>{r1(goals.calories-tot.cal)}</div></div>
                </div>
              </div>
            </div>)}
            {mp===1&&(<div>
              <div style={{fontSize:11,fontWeight:700,opacity:0.6,letterSpacing:"0.5px",marginBottom:14}}>MACROS</div>
              <div style={{display:"flex",gap:12}}>
                {[{l:"Protein",v:tot.protein,g:goals.protein,c:"#93c5fd"},{l:"Fat",v:tot.fat,g:goals.fat,c:"#fde68a"},{l:"Carbs",v:tot.carbs,g:goals.carbs,c:"#6ee7b7"}].map(m=>{const p=Math.min(100,Math.round((m.v/m.g)*100));return(<div key={m.l} style={{flex:1}}><div style={{fontSize:10,opacity:0.6,fontWeight:700,letterSpacing:"0.5px"}}>{m.l}</div><div style={{fontSize:24,fontWeight:800,lineHeight:1.3}}>{m.v}<span style={{fontSize:12,opacity:0.5}}>/{m.g}g</span></div><div style={{height:5,borderRadius:3,background:"rgba(255,255,255,0.15)",marginTop:6}}><div style={{height:5,borderRadius:3,background:m.c,width:`${p}%`,transition:"width 0.3s"}}/></div></div>);})}
              </div>
            </div>)}
            {mp===2&&(()=>{const rem=getRemaining();const pmt=perMealTarget();const ml=mealsLeft();return(<div>
              <div style={{fontSize:11,fontWeight:700,opacity:0.6,letterSpacing:"0.5px",marginBottom:10}}>REMAINING TODAY · {ml} MEAL{ml!==1?"S":""} LEFT</div>
              <div style={{display:"flex",gap:16}}>
                <div><div style={{fontSize:10,opacity:0.5,fontWeight:600}}>Total left</div><div style={{fontSize:22,fontWeight:800}}>{rem.cal} <span style={{fontSize:11,opacity:0.5}}>cal</span></div></div>
