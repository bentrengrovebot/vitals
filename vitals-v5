              <div style={{display:"flex",gap:4}}>
                {w.days.map((d,i)=>{
                  const p=goals.calories>0?Math.min(100,Math.round((d.cal/goals.calories)*100)):0;
                  const isToday=d.dk===dk();
                  return(<div key={i} style={{flex:1,textAlign:"center"}}>
                    <div style={{fontSize:10,fontWeight:600,color:isToday?ac:t3,marginBottom:4}}>{d.dayName}</div>
                    <div style={{height:40,borderRadius:6,background:brd,position:"relative",overflow:"hidden"}}>
                      <div style={{position:"absolute",bottom:0,width:"100%",height:`${p}%`,borderRadius:6,background:p>100?rd:isToday?`linear-gradient(180deg,${ac},${pu})`:d.hasData?"#c7d2fe":"transparent",transition:"height 0.3s"}}/>
